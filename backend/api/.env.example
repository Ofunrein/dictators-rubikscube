NODE_ENV=development
PORT=4011
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rubiks_app?schema=public
FRONTEND_ORIGIN=http://localhost:5173

# AI Coach — set AI_PROVIDER=openai + AI_PROVIDER_API_KEY to enable real coaching.
# Free tier: Groq (https://console.groq.com). Leave AI_PROVIDER=mock for offline/demo.
AI_PROVIDER=mock
AI_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=https://api.groq.com/openai
AI_PROVIDER_API_KEY=
AI_REQUEST_TIMEOUT_MS=12000

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL_MINUTES=15
REFRESH_COOKIE_NAME=refresh_token
REFRESH_TOKEN_TTL_DAYS=14
