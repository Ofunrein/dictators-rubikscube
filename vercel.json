{
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "crons": [
    {
      "path": "/api/cron/keepalive",
      "schedule": "0 12 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api/v1/[...path]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
